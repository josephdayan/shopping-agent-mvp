DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopping_agent?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/shopping_agent?schema=public"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
API_TOKEN="dev-api-token"
WHATSAPP_PROVIDER="twilio"
WHATSAPP_WEBHOOK_SECRET="dev-webhook-secret"
WHATSAPP_VERIFY_TOKEN="dev-meta-verify-token"
WHATSAPP_APP_SECRET=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_WEBHOOK_URL=""
TWILIO_AGENT_CONNECT_ENABLED="false"
TWILIO_API_KEY=""
TWILIO_API_SECRET=""
TWILIO_CONVERSATION_CONFIGURATION_ID=""
TWILIO_MEMORY_STORE_ID=""
TWILIO_TRAIT_GROUPS="Contact,Preferences"
TWILIO_PRODUCT_OPTIONS_CONTENT_SID=""
TWILIO_PHONE_NUMBER=""
TWILIO_VOICE_PUBLIC_DOMAIN=""
MERCADO_LIVRE_REAL_SEARCH="false"
MERCADO_LIVRE_CLIENT_ID=""
MERCADO_LIVRE_CLIENT_SECRET=""
MERCADO_LIVRE_REDIRECT_URI="https://shopping-agent-mvp.vercel.app/api/mercadolivre/callback"
MERCADO_LIVRE_ACCESS_TOKEN=""
MERCADO_LIVRE_REFRESH_TOKEN=""
MERCADO_LIVRE_SEARCH_LIMIT="8"
MERCADO_LIVRE_DEFAULT_SHIPPING="12.90"
MERCADO_LIVRE_DEFAULT_DELIVERY_HOURS="48"

# --- Real product search (Apify is the authoritative source) ---
# REQUIRED for real results. Without it, search returns nothing and the bot
# tells the user it found no options. Set this in Vercel (Production + Preview).
APIFY_API_TOKEN=""
# Apify actor that scrapes Mercado Livre Brasil. Default below already works.
APIFY_MERCADO_LIVRE_ACTOR="karamelo/mercadolivre-scraper-brasil-portugues"
APIFY_WEBHOOK_SECRET="dev-webhook-secret"
APIFY_MERCADO_LIVRE_CALLBACK_URL="https://your-vercel-domain.vercel.app/api/apify/mercadolivre/callback"
APIFY_MERCADO_LIVRE_MAX_PAGES="1"
APIFY_MERCADO_LIVRE_TIMEOUT_SECONDS="60"

# --- Lia search tuning (optional; ATLAS_* keys still read as fallback) ---
# How many cards to show per batch (default 3).
LIA_SEARCH_BATCH_SIZE="3"
# How many candidates to fetch before curation (default auto).
LIA_SEARCH_CANDIDATE_SIZE=""
# Set "true" only to allow mock/generated products when no real result is found.
LIA_ALLOW_MOCK_RESULTS_FOR_SEARCH="false"
LIA_ALLOW_GENERATED_FALLBACKS="false"

# --- Search cache + prewarm cron (instant repeat/refine, no ~50s cold start) ---
# How long a cached scrape is served before it's considered stale (default 7 days).
LIA_SEARCH_CACHE_TTL_MS="604800000"
# How many of the ~100 prewarm queries each cron run refreshes (default 6).
LIA_PREWARM_BATCH="6"
# Set this in Vercel to let the scheduled cron authenticate (Vercel injects it as
# `Authorization: Bearer <CRON_SECRET>`). Optional but recommended.
CRON_SECRET=""

# --- Everyday-delivery flow (Carrefour + courier + Pix). All have sandbox/mock
#     fallbacks, so the whole flow runs end-to-end before these are set. ---
# Your margin: a markup baked into product prices (1.1 = +10%, no separate fee line).
LIA_PRICE_MARKUP="1.1"
# Mock courier base fee (used until a courier's creds are set).
LIA_COURIER_BASE_FEE="9.9"
# All registered couriers are quoted in parallel and the CHEAPEST wins. Per-courier
# quote timeout (ms) so one slow courier never hangs the WhatsApp turn.
LIA_COURIER_QUOTE_TIMEOUT_MS="8000"
# Offer the customer a "cheapest vs fastest" frete choice (default off — only worth it
# once couriers return a reliable ETA; Lalamove currently doesn't). Off = always cheapest.
LIA_OFFER_FRETE_CHOICE="false"
# Carrefour clique-e-retire minimum order (R$ of products). Per-store rule, not global.
LIA_CARREFOUR_MIN_ORDER="30"
# Carrefour catalog: ~1094 REAL items in src/lib/stores/carrefour-catalog.ts.
# The live Apify scrape is OPT-IN and dormant (community actor broken). Empty = seed.
APIFY_CARREFOUR_ACTOR="gio21~carrefour-br-scraper"
# Uber Direct (self-serve last-mile). Empty = realistic mock quotes/dispatch.
#   CUSTOMER_ID = your Uber Direct org id. Auth: set CLIENT_ID + CLIENT_SECRET
#   (preferred — we mint+cache the OAuth token) OR a pre-minted TOKEN directly.
UBER_DIRECT_CUSTOMER_ID=""
UBER_DIRECT_CLIENT_ID=""
UBER_DIRECT_CLIENT_SECRET=""
UBER_DIRECT_TOKEN=""
# Who/what the courier sees as the PICKUP party at the store counter (the operator).
UBER_DIRECT_PICKUP_NAME="Lia"
UBER_DIRECT_PICKUP_PHONE=""
# Lalamove (self-serve on-demand courier in SP). Empty = mock. Get an API key at
# partnerportal.lalamove.com (sandbox pk_test/sk_test -> prod pk_prod/sk_prod). Auth is
# HMAC. LALAMOVE_ENV=prod switches the base URL. Lalamove needs lat/lng, geocoded via
# BrasilAPI/Nominatim. Sender defaults to the Uber pickup name/phone unless overridden.
LALAMOVE_API_KEY=""
LALAMOVE_API_SECRET=""
LALAMOVE_ENV="sandbox"
LALAMOVE_MARKET="BR_SAO"
LALAMOVE_SERVICE_TYPE="MOTORCYCLE"
LALAMOVE_SENDER_NAME=""
LALAMOVE_SENDER_PHONE=""
# Loggi (courier #3). Credentials are NOT self-serve — onboard via contato@loggi.com,
# then set these. The real API (GraphQL) is a stub to finalize during onboarding; until
# then Loggi stays mock and is excluded from the comparison whenever another courier is real.
LOGGI_CLIENT_ID=""
LOGGI_CLIENT_SECRET=""
LOGGI_ENV="sandbox"
# Mercado Pago (money-in). Empty = mock link + "responda paguei" in chat. The SAME
# access token powers the Checkout Pro link (CARD + Pix on one MP-hosted page) the
# customer pays on — make sure CARD acceptance is enabled in the MP dashboard, not
# just Pix, or the link will only show Pix.
MERCADO_PAGO_ACCESS_TOKEN=""
# Webhook hardening: public URL of /api/mercadopago/webhook (sent per-payment), and the
# signing secret from the MP webhook config (when set, we verify the x-signature HMAC).
MERCADO_PAGO_WEBHOOK_URL=""
MERCADO_PAGO_WEBHOOK_SECRET=""
# Public base URL of the app, used for the Checkout Pro back_urls (where MP sends the
# customer after paying). Defaults to the production domain if unset.
LIA_PUBLIC_URL="https://shopping-agent-mvp.vercel.app"
# Card MDR passed through to customers who pay by card (gross-up so the 10% margin
# survives). Tune down as your Mercado Pago volume lowers the rate.
LIA_CARD_MDR="0.0499"
# Product photos in WhatsApp options (Carrefour VTEX CDN images). Set to "false" to
# fall back to a single numbered-text message (e.g. before the Business sender is approved).
LIA_SEND_PHOTOS="true"
# Image hosts WhatsApp/Twilio can't fetch (Akamai/anti-bot) — media is skipped and the
# option falls back to text so we never send a broken image. Petz self-hosts photos behind
# Akamai (they 403 server-side; Carrefour's VTEX CDN is fine). The Petz imageUrls still
# power the /ops dashboard and a future re-host to a public CDN — clear this host once
# re-hosted. Comma-separated; empty string disables the blocklist.
LIA_MEDIA_BLOCK_HOSTS="images.petz.com.br"
# Token to open the operator dashboard: /ops?key=<this>. Falls back to API_TOKEN.
OPS_TOKEN=""

# --- Automated retailer purchasing (Carrefour pilot) ---
# Starts safe: "cart_only" may resolve products and build a cart, but never places an order.
# Switch to "approval_required" only after the Carrefour account/card/pickup flow has been
# validated. "policy" permits automatic buying only inside the guardrails below.
PURCHASE_AUTOMATION_MODE="cart_only"
PURCHASE_AUTO_APPROVE_MAX_TOTAL="0"
PURCHASE_MAX_PRICE_DELTA="5"
PURCHASE_MAX_PRICE_DELTA_PERCENT="0.03"
PURCHASE_APPROVAL_TTL_MINUTES="10"
PURCHASE_POLL_MINUTES="5"

# Remote persistent browser. Create one Browserbase Context per retailer account and never
# commit its ID alongside credentials. The card remains saved at the retailer, not in Lia.
BROWSERBASE_API_KEY=""
CARREFOUR_BROWSER_CONTEXT_ID=""
CARREFOUR_BROWSER_PROXY_COUNTRY="br"
