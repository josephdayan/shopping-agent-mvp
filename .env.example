MERCADO_LIVRE_DEFAULT_SHIPPING="12.90"
MERCADO_LIVRE_DEFAULT_DELIVERY_HOURS="48"

# --- Real product search (Apify is the authoritative source) ---
# REQUIRED for real results. Without it, search returns nothing and the bot
# tells the user it found no options. Set this in Vercel (Production + Preview).
APIFY_API_TOKEN=""
# Apify actor that scrapes Mercado Livre Brasil. Default below already works.
APIFY_MERCADO_LIVRE_ACTOR="karamelo/mercadolivre-scraper-brasil-portugues"
APIFY_WEBHOOK_SECRET="dev-webhook-secret"
APIFY_MERCADO_LIVRE_CALLBACK_URL="https://your-vercel-domain.vercel.app/api/apify/mercadolivre/callback"
APIFY_MERCADO_LIVRE_MAX_PAGES="1"
APIFY_MERCADO_LIVRE_TIMEOUT_SECONDS="60"

# --- Lia search tuning (optional; ATLAS_* keys still read as fallback) ---
# How many cards to show per batch (default 3).
LIA_SEARCH_BATCH_SIZE="3"
# How many candidates to fetch before curation (default auto).
LIA_SEARCH_CANDIDATE_SIZE=""
# Set "true" only to allow mock/generated products when no real result is found.
LIA_ALLOW_MOCK_RESULTS_FOR_SEARCH="false"
LIA_ALLOW_GENERATED_FALLBACKS="false"
