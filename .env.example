DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopping_agent?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/shopping_agent?schema=public"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
API_TOKEN="dev-api-token"
WHATSAPP_PROVIDER="twilio"
WHATSAPP_WEBHOOK_SECRET="dev-webhook-secret"
WHATSAPP_VERIFY_TOKEN="dev-meta-verify-token"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_WEBHOOK_URL=""
TWILIO_AGENT_CONNECT_ENABLED="false"
TWILIO_API_KEY=""
TWILIO_API_SECRET=""
TWILIO_CONVERSATION_CONFIGURATION_ID=""
TWILIO_MEMORY_STORE_ID=""
TWILIO_TRAIT_GROUPS="Contact,Preferences"
TWILIO_PRODUCT_OPTIONS_CONTENT_SID=""
TWILIO_PHONE_NUMBER=""
TWILIO_VOICE_PUBLIC_DOMAIN=""
MERCADO_LIVRE_REAL_SEARCH="false"
MERCADO_LIVRE_CLIENT_ID=""
MERCADO_LIVRE_CLIENT_SECRET=""
MERCADO_LIVRE_REDIRECT_URI="https://shopping-agent-mvp.vercel.app/api/mercadolivre/callback"
MERCADO_LIVRE_ACCESS_TOKEN=""
MERCADO_LIVRE_REFRESH_TOKEN=""
MERCADO_LIVRE_SEARCH_LIMIT="8"
MERCADO_LIVRE_DEFAULT_SHIPPING="12.90"
MERCADO_LIVRE_DEFAULT_DELIVERY_HOURS="48"

# --- Real product search (Apify is the authoritative source) ---
# REQUIRED for real results. Without it, search returns nothing and the bot
# tells the user it found no options. Set this in Vercel (Production + Preview).
APIFY_API_TOKEN=""
# Apify actor that scrapes Mercado Livre Brasil. Default below already works.
APIFY_MERCADO_LIVRE_ACTOR="karamelo/mercadolivre-scraper-brasil-portugues"
APIFY_WEBHOOK_SECRET="dev-webhook-secret"
APIFY_MERCADO_LIVRE_CALLBACK_URL="https://your-vercel-domain.vercel.app/api/apify/mercadolivre/callback"
APIFY_MERCADO_LIVRE_MAX_PAGES="1"
APIFY_MERCADO_LIVRE_TIMEOUT_SECONDS="60"

# --- Lia search tuning (optional; ATLAS_* keys still read as fallback) ---
# How many cards to show per batch (default 3).
LIA_SEARCH_BATCH_SIZE="3"
# How many candidates to fetch before curation (default auto).
LIA_SEARCH_CANDIDATE_SIZE=""
# Set "true" only to allow mock/generated products when no real result is found.
LIA_ALLOW_MOCK_RESULTS_FOR_SEARCH="false"
LIA_ALLOW_GENERATED_FALLBACKS="false"

# --- Search cache + prewarm cron (instant repeat/refine, no ~50s cold start) ---
# How long a cached scrape is served before it's considered stale (default 7 days).
LIA_SEARCH_CACHE_TTL_MS="604800000"
# How many of the ~100 prewarm queries each cron run refreshes (default 6).
LIA_PREWARM_BATCH="6"
# Set this in Vercel to let the scheduled cron authenticate (Vercel injects it as
# `Authorization: Bearer <CRON_SECRET>`). Optional but recommended.
CRON_SECRET=""

# --- Everyday-delivery flow (Carrefour + courier + Pix). All have sandbox/mock
#     fallbacks, so the whole flow runs end-to-end before these are set. ---
# Your flat service fee per order (your margin; product + courier are pass-through).
LIA_SERVICE_FEE="7.9"
# Mock courier base fee (used until Uber Direct creds are set).
LIA_COURIER_BASE_FEE="9.9"
# Uber Direct (self-serve last-mile). Empty = realistic mock quotes/dispatch.
UBER_DIRECT_CUSTOMER_ID=""
UBER_DIRECT_TOKEN=""
# Mercado Pago (Pix money-in). Empty = mock copia-e-cola + "responda paguei" in chat.
MERCADO_PAGO_ACCESS_TOKEN=""
# Token to open the operator dashboard: /ops?key=<this>. Falls back to API_TOKEN.
OPS_TOKEN=""
